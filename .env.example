# ═══════════════════════════════════════════════════════════
# NIGHTOS — environment variables
#
# Every variable below is OPTIONAL. The app runs with mock data
# and a stub Ruri-Mama AI when nothing is set, which is ideal
# for the initial demo.
# ═══════════════════════════════════════════════════════════

# ─── Anthropic Claude API (optional) ─────────────────────────
# Leave empty to use the built-in deterministic stub responses
# (still customer-aware). Set this to enable the real さくらママ.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Supabase (optional) ─────────────────────────────────────
# Leave both empty to run on in-memory mock data. Both are
# required together — if only one is set the app still falls
# back to mock mode.
# After `supabase start`, copy the displayed values here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Supabase Service Role (only for /api/setup-auth) ────────
# Required ONLY to create test Auth users via /api/setup-auth.
# NEVER expose this key client-side. Get it from Supabase
# Dashboard → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Mock auth gate (staging/production) ─────────────────────
# Set to "true" on staging/production to disable the cast-selector
# login path. Users must then authenticate via Supabase Auth
# (email/password). Leave empty/unset on local dev for convenience.
NIGHTOS_DISABLE_MOCK_AUTH=

# ─── /setup admin gate ───────────────────────────────────────
# Strong random string (≥16 chars). Required to access the
# /setup UI and /api/setup{,-auth} endpoints. Without this
# variable both routes return 404 — even with the previously
# hardcoded `nightos-setup-2026` query string.
#
# Generate with: openssl rand -hex 24
# Production deployments should LEAVE THIS UNSET unless they
# are intentionally seeding demo data into prod.
NIGHTOS_SETUP_SECRET=

# ─── App canonical URL ───────────────────────────────────────
# Used for OG tags / metadataBase. Set to your production
# domain. Falls back to https://example.com when unset (which
# is fine for dev but breaks share previews on Vercel preview).
NEXT_PUBLIC_APP_URL=

# ─── Error reporting (optional) ──────────────────────────────
# When wired to Sentry/Honeycomb/Datadog, drop the DSN here and
# update lib/nightos/error-reporter.ts to forward. Leaving it
# empty keeps errors flowing to Vercel Function Logs only.
NEXT_PUBLIC_SENTRY_DSN=
