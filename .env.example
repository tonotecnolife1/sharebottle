# ═══════════════════════════════════════════════════════════
# NIGHTOS — environment variables
#
# Every variable below is OPTIONAL. The app runs with mock data
# and a stub Ruri-Mama AI when nothing is set, which is ideal
# for the initial demo.
# ═══════════════════════════════════════════════════════════

# ─── Anthropic Claude API (optional) ─────────────────────────
# Leave empty to use the built-in deterministic stub responses
# (still customer-aware). Set this to enable the real さくらママ.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Supabase (optional) ─────────────────────────────────────
# Leave both empty to run on in-memory mock data. Both are
# required together — if only one is set the app still falls
# back to mock mode.
# After `supabase start`, copy the displayed values here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Supabase Service Role (only for /api/setup-auth) ────────
# Required ONLY to create test Auth users via /api/setup-auth.
# NEVER expose this key client-side. Get it from Supabase
# Dashboard → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=
